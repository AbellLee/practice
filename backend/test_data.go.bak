package main

import (
	"fmt"
	"practice-system/models"
)

func main() {
	models.InitDB()
	
	// 检查题目数量
	var count int64
	models.GetDB().Model(&models.Question{}).Count(&count)
	fmt.Printf("题目总数：%d\n", count)
	
	// 获取所有题目
	var questions []models.Question
	models.GetDB().Find(&questions)
	
	if len(questions) > 0 {
		fmt.Println("\n题目列表:")
		for _, q := range questions {
			fmt.Printf("ID: %d, 标题：%s, 类型：%s\n", q.ID, q.Title, q.Type)
		}
	} else {
		fmt.Println("数据库中没有题目")
	}
	
	fmt.Println("\n按回车键退出...")
	fmt.Scanln()
}
